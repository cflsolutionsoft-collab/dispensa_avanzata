rules_version = '2';

// Regole di sicurezza Firestore per Pantry AI.
// Principio: ogni utente accede solo ai propri dati sotto users/{uid}/...
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: utente autenticato e proprietario del documento
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Documento profilo utente (lettura/scrittura solo del proprietario)
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // Tutte le sottocollezioni dell'utente: pantry, staples, shoppingList,
      // photoSessions, recipes, activity. Stessa regola: solo il proprietario.
      match /{collection}/{docId} {
        allow read, write: if isOwner(uid);
      }
    }

    // Tutto il resto è negato di default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
